generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  CUSTOMER
}

enum AvailabilityStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id         String  @id @default(cuid())
  supabaseId String  @unique
  fullName   String
  email      String  @unique
  phone      String?

  role Role @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  halls           Hall[]
  bookingRequests BookingRequest[]
  favorites       Favorite[]
  reviews         Review[]
}

model Hall {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name String
  slug String @unique

  description String

  address String
  area    String

  latitude  Float
  longitude Float

  pricePerDay Int

  minCapacity Int
  maxCapacity Int

  parking    Boolean @default(false)
  ac         Boolean @default(false)
  kitchen    Boolean @default(false)
  rooms      Int     @default(0)
  diningHall Boolean @default(false)
  generator  Boolean @default(false)

  contactPhone String

  featured Boolean @default(false)
  approved Boolean @default(false)

  rating       Float @default(0)
  totalReviews Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images          HallImage[]
  availability    Availability[]
  bookingRequests BookingRequest[]
  favorites       Favorite[]
  reviews         Review[]
}

model HallImage {
  id String @id @default(cuid())

  hallId String
  hall   Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  imageUrl String

  displayOrder Int @default(0)

  createdAt DateTime @default(now())
}

model Availability {
  id String @id @default(cuid())

  hallId String
  hall   Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  date DateTime

  status AvailabilityStatus @default(AVAILABLE)

  createdAt DateTime @default(now())

  @@unique([hallId, date])
}

model BookingRequest {
  id String @id @default(cuid())

  hallId String
  hall   Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventDate DateTime

  guests Int

  message String?

  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  hallId String
  hall   Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, hallId])
}

model Review {
  id String @id @default(cuid())

  hallId String
  hall   Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating Int

  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hallId, userId])
}
